{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "llm-wiki",
  "version": "2.0.0",
  "identifier": "com.roger8b.llmwiki",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../../src/llmwiki/interfaces/api/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/wiki-backend"]
  }
}
