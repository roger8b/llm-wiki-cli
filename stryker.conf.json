{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": [
    "html",
    "json",
    "progress"
  ],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "ignorePatterns": [
    ".claude",
    ".llm-wiki.json",
    "AGENTS.md",
    "CLAUDE.md",
    "reports",
    "coverage",
    ".stryker-tmp"
  ],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/utils/paths.ts",
    "src/utils/global-config.ts"
  ],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 80
  }
}