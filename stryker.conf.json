{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts",
    "related": false
  },
  "mutate": [
    "src/utils/**/*.ts",
    "!src/**/*.d.ts"
  ],
  "ignorePatterns": [
    ".claude",
    ".stryker-tmp",
    "node_modules",
    "coverage"
  ],
  "mutator": {
    "excludedMutations": ["booleanLiteral", "stringLiteral"]
  },
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 60
  },
  "timeoutMS": 5000,
  "tempDirName": "/tmp/stryker-wiki-cli"
}