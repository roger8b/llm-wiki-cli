{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": [
    "html",
    "json",
    "progress"
  ],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts",
    "related": false
  },
  "mutate": [
    "src/utils/**/*.ts",
    "!src/**/*.d.ts"
  ],
  "ignorePatterns": [
    ".claude",
    ".llm-wiki.json",
    "AGENTS.md",
    "CLAUDE.md",
    "reports",
    "coverage",
    ".stryker-tmp"
  ],
  "mutator": {
    "excludedMutations": ["stringLiteral"]
  },
  "thresholds": {
    "high": 50,
    "low": 40,
    "break": 0
  },
  "timeoutMS": 5000,
  "tempDirName": "/tmp/stryker-wiki-cli"
}
